---
/**
 * Base-Layout — HTML-Shell, Head (Meta/OG/Schema), Fonts (lokal/DSGVO), Header + Footer.
 * Alle Seiten nutzen dieses Layout. Phase 2: CSP-Header, PWA-Manifest, Analytics ergänzen.
 */
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/hanken-grotesk';
import '../styles/global.css';
import Header from '../components/Header.astro';
import MobileNav from '../components/MobileNav.astro';
import Footer from '../components/Footer.astro';
import FloatingActions from '../components/FloatingActions.astro';
import AppTabBar from '../components/AppTabBar.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Auto-Teiler Grasbrunn e.V. — Carsharing dahoam in Grasbrunn',
  description = 'Carsharing in Grasbrunn/Neukeferloh: Auto teilen statt besitzen. Kein Monatsbeitrag, Versicherung & Kraftstoff inklusive, vom E-Auto bis zum 9-Sitzer Kleinbus. Jetzt einfach Mitglied werden.',
} = Astro.props;

// Vorschau-Build (Pages-Unterordner, base !== '/') NICHT indexieren — sonst
// taucht die github.io-Vorschau in Suchmaschinen auf und konkurriert später
// mit der echten Live-Domain (Duplicate Content). Live-Build (base '/') = indexierbar.
const base = import.meta.env.BASE_URL;
const isPreview = base !== '/';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Auto-Teiler Grasbrunn e.V.',
  alternateName: 'ATG',
  slogan: 'Carsharing dahoam — weniger Autos, dennoch mobil.',
  url: 'https://www.atg-grasbrunn.de/',
  email: 'info@atg-grasbrunn.de',
  telephone: '+49 89 21541339',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Winklerring 12',
    postalCode: '85630',
    addressLocality: 'Grasbrunn',
    addressRegion: 'Bayern',
    addressCountry: 'DE',
  },
  areaServed: ['Grasbrunn', 'Neukeferloh', 'Harthausen', 'Möschenfeld', 'Keferloh', 'Landkreis München'],
  sameAs: ['https://www.carsharing-vaterstetten.de/'],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{title}</title>
    <meta name="description" content={description} />
    {isPreview && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#d42a22" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%23d42a22'/%3E%3Ctext x='16' y='22' font-family='Arial' font-weight='800' font-size='14' fill='%23ffc400' text-anchor='middle'%3EATG%3C/text%3E%3C/svg%3E"
    />
    <!-- PWA: installierbar als App (Icon auf Handy/Desktop) -->
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="apple-touch-icon" href={`${base}icons/apple-touch-icon.png`} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="ATG Carsharing" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} is:inline />
  </head>
  <body>
    <a class="skip-link" href="#main">Zum Inhalt springen</a>
    <Header />
    <MobileNav />
    <main id="main"><slot /></main>
    <Footer />
    <FloatingActions />
    <AppTabBar />
    <style>
      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        z-index: var(--z-skip);
        background: var(--color-ink);
        color: #fff;
        padding: 0.7rem 1rem;
        border-radius: 0 0 8px 0;
        font-weight: 700;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>

    <script>
      // Lenis Smooth-Scroll global initialisieren — geschmeidiges Ausrollen.
      // Bei prefers-reduced-motion: nativ scrollen (kein Lenis), barrierefrei.
      import Lenis from 'lenis';
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // PWA: Service Worker registrieren (installierbar + Offline-Shell).
      if ('serviceWorker' in navigator) {
        const swBase = import.meta.env.BASE_URL;
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swBase + 'sw.js', { scope: swBase }).catch(() => {});
        });
      }

      if (!reduce) {
        const lenis = new Lenis({
          duration: 1.1,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });
        (window as any).lenis = lenis;
        const raf = (time: number) => { lenis.raf(time); requestAnimationFrame(raf); };
        requestAnimationFrame(raf);

        // Interne Anker-Links (#... und /#...) geschmeidig anspringen, mit Header-Offset.
        document.querySelectorAll<HTMLAnchorElement>('a[href*="#"]').forEach((a) => {
          const href = a.getAttribute('href') || '';
          const hash = href.includes('#') ? '#' + href.split('#')[1] : '';
          if (!hash || hash === '#') return;
          a.addEventListener('click', (e) => {
            const target = document.querySelector(hash);
            if (target) { e.preventDefault(); lenis.scrollTo(target as HTMLElement, { offset: -72 }); }
          });
        });
      }

      // Scroll-Reveal: Elemente mit .reveal beim Sichtbarwerden einblenden.
      const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
      if (revealEls.length && !reduce) {
        const ro = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in-view'); ro.unobserve(e.target); } });
        }, { rootMargin: '0px 0px -8% 0px' });
        revealEls.forEach((el) => ro.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('in-view'));
      }

      // Zahlen hochzählen (Elemente mit data-count) beim Sichtbarwerden.
      const counters = document.querySelectorAll<HTMLElement>('[data-count]');
      if (counters.length) {
        const run = (el: HTMLElement) => {
          const target = parseFloat(el.getAttribute('data-count') || '0');
          const suffix = el.getAttribute('data-suffix') || '';
          if (reduce) { el.textContent = target.toLocaleString('de-DE') + suffix; return; }
          const dur = 1100; const t0 = performance.now();
          const step = (t: number) => {
            const p = Math.min(1, (t - t0) / dur);
            el.textContent = Math.round(target * (1 - Math.pow(1 - p, 3))).toLocaleString('de-DE') + suffix;
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
        };
        const co = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { run(e.target as HTMLElement); co.unobserve(e.target); } });
        }, { threshold: 0.6 });
        counters.forEach((el) => co.observe(el));
      }
    </script>
  </body>
</html>
