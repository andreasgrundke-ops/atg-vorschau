---
/**
 * Startseite ATG Carsharing — Durchstich in neuer CI (Rot/Gelb aus Logo & Fahrzeugen).
 * Sektionen: Hero · Stat-Leiste · So geht's · Flotte · Preise+Kostenrechner · Kooperation · FAQ · CTA.
 * Fahrzeugfotos: aktuell von der Live-Seite referenziert → Phase 2 lokal + WebP/AVIF + srcset.
 */
import Base from '../layouts/Base.astro';
import StandorteKarte from '../components/StandorteKarte.astro';

const base = import.meta.env.BASE_URL;
const heroPhoto = 'https://www.atg-grasbrunn.de/wp-content/uploads/2024/09/WhatsApp-Bild-2024-09-01-um-12.45.09_ef67264d-1.jpg';
const BOOK = 'https://www.atg-grasbrunn.de/mitgliederbereich/';

// Hero-Slider: echte Fahrzeugfotos (KFZ). Jeder Slide hat eine eigene Botschaft
// (h1 zweizeilig, 2. Zeile = gelber Akzent) + Lead + Tag.
// pos = background-position (verhindert „zu groß"/abgeschnitten wirkende Motive).
const heroSlides = [
  {
    kind: 'kfz', img: heroPhoto, pos: 'center 55%',
    h1a: 'Weniger Autos', h1b: 'dennoch mobil.',
    lead: 'Teil dir ein Auto, statt eins zu besitzen — vom E-Auto bis zum 9-Sitzer Kleinbus, direkt um die Ecke. <strong>Ohne Monatsbeitrag.</strong>',
    tag: 'Renault ZOE — emissionsfrei · ab 1 €/h zzgl. km · Kraftstoff inklusive',
  },
  {
    kind: 'kfz', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/03/20220322_161630.jpg', pos: 'center 50%',
    h1a: 'Ganze Gruppe?', h1b: 'Alle rein.',
    lead: 'Der 9-Sitzer Kleinbus bringt Verein, Familie oder Freunde gemeinsam ans Ziel — echte Sitzplätze statt Gedränge.',
    tag: 'Renault Trafic — 9-Sitzer Kleinbus für Gruppen & Ausflüge',
  },
  {
    kind: 'kfz', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/12/20221204_151256.jpg', pos: 'center 55%',
    h1a: 'Einer für', h1b: 'jeden Weg.',
    lead: 'Kombi, Kleinwagen oder E-Auto — fünf Fahrzeugklassen an festen Stellplätzen in Neukeferloh.',
    tag: 'Renault Clio Grandtour — Kombi für Einkauf & Ausflug',
  },
];

// Führerscheinklasse: alle Fahrzeuge ≤ 3,5 t und ≤ 9 Sitze → Klasse B (alt: Klasse 3).
// ISOFIX: alle Fahrzeuge haben ISOFIX-Halterungen für Kindersitze.
// ahk (Anhängerkupplung): null = noch bestätigen (Angabe folgt vom Verein).
const cars = [
  {
    slug: 'zoe', name: 'Renault ZOE', type: 'Elektro · emissionsfrei', badge: 'E-Auto',
    loc: 'Am Rathaus, Neukeferloh', seats: '5 Sitze', tarif: 'ab 0,45 €/km',
    antrieb: 'Elektro', schaltung: 'Automatik', isofix: true, fuehrerschein: 'Klasse B (alt: 3)', ahk: null,
    img: heroPhoto,
  },
  {
    slug: 'corsa', name: 'Opel Corsa', type: 'Wendiger Stadtflitzer', badge: 'Kleinwagen',
    loc: 'Finkenstraße, hinter der Kirche', seats: '5 Sitze', tarif: 'ab 0,40 €/km',
    antrieb: 'Benzin', schaltung: 'Schaltgetriebe', isofix: true, fuehrerschein: 'Klasse B (alt: 3)', ahk: null,
    img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2025/07/Opel-Corsa-NEU.jpg',
  },
  {
    slug: 'sandero', name: 'Dacia Sandero', type: 'Günstig & praktisch', badge: 'Kleinwagen',
    loc: 'Ecke Waldstraße / Saarlandstraße', seats: '5 Sitze', tarif: 'ab 0,40 €/km',
    antrieb: 'Benzin', schaltung: 'Schaltgetriebe', isofix: true, fuehrerschein: 'Klasse B (alt: 3)', ahk: null,
    img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2025/07/Dacia-Sandero-NEU-1.jpg',
  },
  {
    slug: 'clio', name: 'Renault Clio Grandtour', type: 'Kombi mit großem Kofferraum', badge: 'Kombi',
    loc: 'Dianastraße (beim Orterer), Neukeferloh', seats: '5 Sitze · großer Kofferraum', tarif: 'ab 0,45 €/km',
    antrieb: 'Benzin', schaltung: 'Schaltgetriebe', isofix: true, fuehrerschein: 'Klasse B (alt: 3)', ahk: null,
    img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/12/20221204_151256.jpg',
  },
  {
    slug: 'trafic', name: 'Renault Trafic', type: 'Kleinbus — 9 Sitze für Gruppen & Ausflüge', badge: 'Kleinbus · 9 Sitze',
    loc: 'Neukeferloh', seats: '9 Sitze', tarif: 'ab 0,60 €/km',
    antrieb: 'Diesel', schaltung: 'Schaltgetriebe', isofix: true, fuehrerschein: 'Klasse B (alt: 3)', ahk: null,
    img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/03/20220322_161630.jpg',
  },
];

// Ausstattungs-Chips fürs Karten-Detail (unter der Kurz-Meta). Sitze & Schaltung
// stehen bereits in der Meta-Zeile → hier die weiteren Fahrzeug-Details.
const equip = (c) => [
  { ic: 'fuel', t: c.antrieb },
  { ic: 'child', t: 'ISOFIX' },
  { ic: 'licence', t: c.fuehrerschein },
  { ic: 'trailer', t: c.ahk === true ? 'mit AHK' : c.ahk === false ? 'ohne AHK' : 'AHK auf Anfrage' },
];

// Inline-SVG-Icons (aria-hidden, dekorativ). Lucide-Stil, stroke=currentColor.
const S = 'viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"';
const icons = {
  fuel: `<svg ${S}><line x1="3" y1="22" x2="15" y2="22"/><line x1="4" y1="9" x2="14" y2="9"/><path d="M14 22V4a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v18"/><path d="M14 13h2a2 2 0 0 1 2 2v2a2 2 0 0 0 4 0V9.83a2 2 0 0 0-.59-1.42L18 5"/></svg>`,
  child: `<svg ${S}><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2 2 4-4.5"/></svg>`,
  licence: `<svg ${S}><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="9" cy="12" r="2"/><path d="M14 10h4M14 14h3"/></svg>`,
  trailer: `<svg ${S}><rect x="2" y="8" width="14" height="8" rx="1"/><path d="M16 14h2"/><circle cx="20" cy="16" r="2"/></svg>`,
};

const steps = [
  { n: '1', h: 'Online melden', t: 'Kurzes Formular ausfüllen. Wir melden uns mit allen Infos zum Verein und zur Carsharing-Teilnahme.' },
  { n: '2', h: 'Unterlagen & Einlage', t: 'Ausweis und Führerschein nachreichen, einmalig 50 € Aufnahme und 600 € Einlage (bei Austritt zurück).' },
  { n: '3', h: 'Einweisung & losfahren', t: 'Kurze Einweisung vor Ort, Transponderkarte erhalten — ab dann buchst du jedes freie Fahrzeug selbst.' },
];

const faqs = [
  { q: 'Was kostet Carsharing bei ATG?', a: 'Tagsüber ab 1,00 €/Std., nachts ab 0,20 €/Std. — jeweils zzgl. Kilometer ab 0,40 €/km je nach Fahrzeug. Der Kraftstoff ist inklusive: getankt wird mit der Tankkarte im Fahrzeug, du zahlst und verauslagst nichts. Einmalig 50 € Aufnahme und 600 € Einlage (bei Austritt zurück) — je Haushalt einmal, egal wie viele Fahrer. Kein Monatsbeitrag.' },
  { q: 'Wie werde ich Mitglied?', a: 'Online melden, Ausweis und Führerschein nachreichen, Einlage zahlen, kurze Einweisung vor Ort — dann buchst du selbstständig. Je Haushalt genügt eine Mitgliedschaft mit einer Einlage — alle Fahrer im Haushalt sind mit dabei.' },
  { q: 'Wo stehen die Fahrzeuge?', a: 'An festen Stellplätzen in Neukeferloh (u.a. Rathaus, Finkenstraße, Waldstraße/Saarlandstraße). Über die Kooperation mit den Vaterstettener Auto-Teilern kannst du zusätzlich deren Fahrzeuge nutzen.' },
  { q: 'Ist der Kraftstoff im Preis enthalten?', a: 'Ja. Kraftstoff und Versicherung sind in den Kilometerpreisen bereits enthalten. Die Tankkarte liegt im Fahrzeug — du zahlst keinen Cent extra fürs Tanken.' },
  { q: 'Gibt es einen Monatsbeitrag?', a: 'Nein. Nur die einmalige Einlage (rückzahlbar) und der Aufnahmebeitrag. Bezahlt wird nur, was tatsächlich gefahren wird.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Base>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />

  <!-- ============ HERO (Kino-Slider) ============ -->
  <section class="hero" id="top" aria-label="Carsharing in Grasbrunn">
    <div class="hero-bg" aria-hidden="true">
      {heroSlides.map((s, i) => (
        <div
          class:list={['hero-slide', { 'is-active': i === 0, 'hero-slide-mvv': s.kind === 'mvv' }]}
          data-h1a={s.h1a}
          data-h1b={s.h1b}
          data-lead={s.lead}
          data-tag={s.tag}
          style={`background-image:url(${s.img || `${base}img/mvv-motiv.svg`}); background-position:${s.pos};`}
        ></div>
      ))}
    </div>
    <div class="hero-scrim" aria-hidden="true"></div>

    <div class="wrap hero-inner">
      <p class="hero-kicker"><span class="dot"></span> Carsharing dahoam · Grasbrunn &amp; Umgebung</p>
      <h1 class="hero-h1" id="hero-h1">
        <span class="h1a" id="hero-h1a">{heroSlides[0].h1a}</span><br />
        <span class="hl" id="hero-h1b">{heroSlides[0].h1b}</span>
      </h1>
      <p class="hero-lead" id="hero-lead" set:html={heroSlides[0].lead}></p>
      <p class="hero-tag" id="hero-tag">{heroSlides[0].tag}</p>
      <div class="cta-row">
        <a class="btn btn-red" href="#mitglied">Mitglied werden</a>
        <a class="btn btn-yellow" href={BOOK} rel="noopener">Fahrzeug buchen</a>
      </div>
      <ul class="trust">
        <li><span class="ck">✓</span> 5 Fahrzeuge direkt in Neukeferloh</li>
        <li><span class="ck">✓</span> Kein Monatsbeitrag</li>
        <li><span class="ck">✓</span> Versicherung &amp; Kraftstoff inklusive</li>
      </ul>
    </div>

    <div class="hero-dots" role="tablist" aria-label="Fahrzeug-Motive wechseln">
      {heroSlides.map((s, i) => (
        <button
          class:list={['hero-dot', { 'is-on': i === 0 }]}
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`Motiv ${i + 1}`}
        ></button>
      ))}
    </div>

    <a class="hero-scrollcue" href="#so-gehts" aria-label="Weiter zu: So geht's"><span></span></a>
  </section>

  <!-- ============ STAT-LEISTE ============ -->
  <section class="stats">
    <div class="wrap stats-grid">
      <div class="stat"><b data-count="5">5</b><span>Fahrzeuge in Neukeferloh</span></div>
      <div class="stat"><b>0&nbsp;€</b><span>Monatsbeitrag · Kraftstoff inkl.</span></div>
      <div class="stat"><b>ab&nbsp;1&nbsp;€/h</b><span>tagsüber · zzgl. km</span></div>
      <div class="stat"><b>ab&nbsp;0,20&nbsp;€/h</b><span>nachts · zzgl. km</span></div>
    </div>
  </section>

  <!-- ============ SO GEHT'S ============ -->
  <section id="so-gehts" class="sec sec-white">
    <div class="wrap">
      <header class="sec-head reveal">
        <h2>In 3 Schritten Mitglied — und losgefahren</h2>
        <p>Kein kompliziertes Verfahren. Du meldest dich online, wir lernen uns kurz vor Ort kennen, dann fährst du.</p>
      </header>
      <div class="steps">
        {steps.map((s) => (
          <article class="step">
            <div class="step-num">{s.n}</div>
            <h3>{s.h}</h3>
            <p>{s.t}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ FLOTTE ============ -->
  <section id="flotte" class="sec">
    <div class="wrap">
      <header class="sec-head reveal">
        <h2>Fünf Fahrzeuge für jeden Zweck</h2>
        <p>Vom kleinen Stadtflitzer übers E-Auto bis zum 9-Sitzer Kleinbus — alle an festen Stellplätzen in Neukeferloh.</p>
      </header>
      <div class="cars">
        {cars.map((c) => (
          <article class="car" data-car={c.slug}>
            <div class="car-photo">
              <img src={c.img} alt={`${c.name} – ${c.type}`} loading="lazy" width="600" height="400" />
              <span class="car-badge">{c.badge}</span>
            </div>
            <div class="car-body">
              <h3>{c.name}</h3>
              <p class="car-type">{c.type}</p>
              <ul class="car-meta">
                <li><span aria-hidden="true">👤</span> {c.seats}</li>
                <li><span aria-hidden="true">⚙️</span> {c.schaltung}</li>
                <li><span aria-hidden="true">💶</span> {c.tarif}</li>
              </ul>
              <div class="car-equip">
                <b class="car-equip-title">Ausstattung</b>
                <ul class="car-equip-chips">
                  {equip(c).map((e) => (
                    <li><span class="ce-ic" set:html={icons[e.ic]}></span>{e.t}</li>
                  ))}
                </ul>
              </div>
              <button class="car-loc" type="button" data-map={c.slug}>
                <span aria-hidden="true">📍</span> <span class="car-loc-txt">{c.loc}</span><span class="car-loc-go">Karte →</span>
              </button>
            </div>
          </article>
        ))}
        <article class="car car-coop">
          <div class="coop-inner">
            <h3>Kooperation mit Vaterstetten</h3>
            <p>Als Mitglied nutzt du zusätzlich die Fahrzeuge der Vaterstettener Auto-Teiler — beidseitig.</p>
            <a class="btn btn-yellow" href="#kooperation">Mehr zur Kooperation</a>
          </div>
        </article>
      </div>
      <p class="note">Ein Foto je Fahrzeug — ruhig statt wechselnd. Die Fahrzeugdaten sind echt; weitere Fotos je Fahrzeug folgen in Phase 2.</p>
    </div>
  </section>

  <!-- ============ STANDORTE-KARTE ============ -->
  <StandorteKarte />

  <!-- ============ PREISE + KOSTENRECHNER ============ -->
  <section id="preise" class="sec sec-white">
    <div class="wrap">
      <header class="sec-head reveal">
        <h2>Was kostet mich das?</h2>
        <p>Du zahlst nur, was du fährst: Zeit plus Kilometer. Kein Monatsbeitrag, keine versteckten Gebühren.</p>
      </header>

      <blockquote class="pay-claim reveal">
        <p>Gezahlt wird nur für das, was auch tatsächlich gefahren wurde. Und das ist bei uns
          erstaunlich wenig. Wir haben <b>keine Jahresgebühr und keine Monatsgebühr</b> — nur wer
          fährt, zahlt auch. <b>Versicherung und Kraftstoff sind in den Preisen bereits enthalten.</b></p>
      </blockquote>

      <div class="price-grid">
        <div class="card price-table">
          <h3>Tarife im Überblick</h3>
          <table>
            <tbody>
              <tr><td>Zeittarif tagsüber (8–20 Uhr)</td><td>ab 1,00 €/h</td></tr>
              <tr><td>Zeittarif nachts (20–8 Uhr)</td><td>ab 0,20 €/h</td></tr>
              <tr><td>Kilometer inkl. Kraftstoff (Kleinwagen)</td><td>ab 0,40 €/km</td></tr>
              <tr><td>Kilometer inkl. Kraftstoff (E-Auto / größer)</td><td>ab 0,45 €/km</td></tr>
              <tr><td>Kilometer inkl. Kraftstoff (Kleinbus, 9 Sitze)</td><td>ab 0,60 €/km</td></tr>
              <tr><td>Aufnahmebeitrag (einmalig)</td><td>50 €</td></tr>
              <tr><td>Einlage — je Haushalt einmal (zurück bei Austritt)</td><td>600 €</td></tr>
              <tr><td>Monatsbeitrag</td><td><span class="free">0 € · keiner</span></td></tr>
            </tbody>
          </table>
          <p class="fine">Stand 04/2026. Versicherung <b>und Kraftstoff inklusive</b> (SB Haftpflicht 200 € / Kasko 600 €). Die Tankkarte liegt im Fahrzeug — Tanken kostet dich keinen Cent extra.</p>
        </div>

        <div class="card calc">
          <h3>Kostenrechner</h3>
          <label for="calc-h">Dauer: <span id="calc-hv" class="val">3 Std.</span> tagsüber</label>
          <input id="calc-h" type="range" min="1" max="24" value="3" step="1" />
          <label for="calc-km">Strecke: <span id="calc-kmv" class="val">30 km</span></label>
          <input id="calc-km" type="range" min="5" max="300" value="30" step="5" />
          <label for="calc-cls">Fahrzeug</label>
          <select id="calc-cls">
            <option value="0.40">Kleinwagen (Corsa / Sandero) – 0,40 €/km</option>
            <option value="0.45">E-Auto / Clio – 0,45 €/km</option>
            <option value="0.60">Kleinbus 9-Sitzer (Trafic) – 0,60 €/km</option>
          </select>
          <div class="calc-result"><span>Beispielpreis</span><b id="calc-total">7,50 €</b></div>
          <p class="fine">Überschlag: Zeittarif (ab 1 €/h tagsüber) + Kilometer — <b>Versicherung und Kraftstoff sind schon drin</b>. Die Tankkarte liegt im Fahrzeug, Tanken kostet dich keinen Cent extra. Echte Abrechnung übers Buchungssystem.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WARUM TEILEN (Vorteil vs. eigenes Auto) ============ -->
  <section id="vorteil" class="sec">
    <div class="wrap">
      <header class="sec-head reveal">
        <h2>Teilen statt besitzen — spart Geld und Aufwand</h2>
        <p>Ein eigenes Auto steht die meiste Zeit ungenutzt herum, kostet aber jeden Monat. Beim Carsharing zahlst du nur, wenn du wirklich fährst — um alles andere kümmert sich der Verein.</p>
      </header>

      <div class="vs reveal">
        <div class="vs-col vs-own">
          <span class="vs-tag">Eigenes Auto</span>
          <ul>
            <li>Anschaffung, Wertverlust, Reparaturen</li>
            <li>Versicherung, Steuer, TÜV, Wartung</li>
            <li>Tanken, Reifenwechsel, Stellplatz</li>
            <li>Aufwand: alles selbst organisieren</li>
          </ul>
        </div>
        <div class="vs-col vs-share">
          <span class="vs-tag vs-tag-on">Carsharing bei ATG</span>
          <ul>
            <li>Nur zahlen, was du fährst — ab 1 €/h</li>
            <li>Versicherung, Kraftstoff &amp; Wartung inklusive</li>
            <li>Tankkarte liegt im Auto — nichts auslegen</li>
            <li>Kein Aufwand — der Verein macht den Rest</li>
          </ul>
        </div>
      </div>

      <div class="perks">
        <article class="perk reveal">
          <span class="perk-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
          </span>
          <h3>Flexibel &amp; schnell buchen</h3>
          <p>Fahrzeug in Sekunden reservieren — am Computer, Tablet oder Handy, rund um die Uhr.</p>
        </article>
        <article class="perk reveal">
          <span class="perk-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M6 15h4"/></svg>
          </span>
          <h3>Zutritt per Transponderkarte</h3>
          <p>Kein Schlüsseltausch: Mit deiner Transponderkarte öffnest du jedes gebuchte Fahrzeug.</p>
        </article>
        <article class="perk reveal">
          <span class="perk-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>
          </span>
          <h3>Ein Haushalt, eine Einlage</h3>
          <p>Je Haushalt zählt eine Mitgliedschaft — nur einmal 600 € Einlage, egal wie viele Fahrer.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ KOOPERATION ============ -->
  <section id="kooperation" class="sec">
    <div class="wrap">
      <header class="sec-head reveal">
        <h2>Gemeinsam mit den Vaterstettener Auto-Teilern</h2>
        <p>Zwei Vereine, eine Idee: Mitglieder nutzen die Fahrzeuge beidseitig — so steht eine gemeinsame Flotte zur Verfügung.</p>
      </header>
      <div class="coop-grid">
        <div class="card">
          <h3>Zwei Vereine, eine Idee</h3>
          <p class="muted-p">In Neukeferloh stehen die ATG-Fahrzeuge. Über die Kooperation mit den Vaterstettener Auto-Teilern nutzt du zusätzlich deren Fahrzeuge — als Mitglied buchst du auf beiden Seiten.</p>
          <a class="btn btn-ghost" href="https://www.carsharing-vaterstetten.de/" rel="noopener">Zu den Vaterstettener Auto-Teilern</a>
        </div>
        <div class="card card-dark">
          <h3>Beidseitig fahren</h3>
          <p>Mehr Auswahl, mehr Verfügbarkeit: Deine Mitgliedschaft gilt auf beiden Seiten der Kooperation.</p>
          <small>Gemeinnützig organisiert · faire Vereinstarife statt teurem Anbieter.</small>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="sec sec-white">
    <div class="wrap wrap-narrow">
      <header class="sec-head reveal">
        <h2>Häufige Fragen</h2>
      </header>
      <div class="faq">
        {faqs.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.q}</summary>
            <div class="faq-a">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ MITGLIED WERDEN (Beitritts-Formular + Dokumente) ============ -->
  <!-- Frontend-only: „Absenden" baut aus den Feldern eine vorausgefüllte E-Mail an
       den Vorstand (kein Backend nötig). Sicherer Server-Endpoint + Führerschein-
       Upload (Modul M5) folgt später — dann nur der Submit-Handler getauscht. -->
