---
/**
 * Startseite ATG Carsharing — Durchstich in neuer CI (Rot/Gelb aus Logo & Fahrzeugen).
 * Sektionen: Hero · Stat-Leiste · So geht's · Flotte · Preise+Kostenrechner · Kooperation · FAQ · CTA.
 * Fahrzeugfotos: aktuell von der Live-Seite referenziert → Phase 2 lokal + WebP/AVIF + srcset.
 */
import Base from '../layouts/Base.astro';
import StandorteKarte from '../components/StandorteKarte.astro';

const base = import.meta.env.BASE_URL;
const heroPhoto = 'https://www.atg-grasbrunn.de/wp-content/uploads/2024/09/WhatsApp-Bild-2024-09-01-um-12.45.09_ef67264d-1.jpg';
const BOOK = 'https://www.atg-grasbrunn.de/mitgliederbereich/';

// Gesamtflotte (ATG + Partner Vaterstetten) — zentral, damit überall konsistent.
const FLEET_TOTAL = 41;

// Hero-Slider: echte Fahrzeugfotos (KFZ) + MVV-Karten-Slide. Jeder Slide hat eine
// eigene Botschaft (h1 zweizeilig, 2. Zeile = gelber Akzent) + Lead + Tag.
// kind: 'kfz' = Foto-Hintergrund · 'mvv' = eigene Illustration (Bus & Bahn).
// pos = background-position (verhindert „zu groß"/abgeschnitten wirkende Motive).
const heroSlides = [
  {
    kind: 'kfz', img: heroPhoto, pos: 'center 55%',
    h1a: 'Weniger Autos.', h1b: 'Dennoch mobil.',
    lead: 'Teil dir ein Auto, statt eins zu besitzen — vom E-Auto bis zum 9-Sitzer, direkt um die Ecke. <strong>Ohne Monatsbeitrag.</strong>',
    tag: 'Renault ZOE — emissionsfrei, ab 1 €/h tagsüber',
  },
  {
    kind: 'kfz', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/03/20220322_161630.jpg', pos: 'center 50%',
    h1a: 'Umzug oder', h1b: 'Großeinkauf?',
    lead: 'Vom Transporter bis zum 9-Sitzer — das passende Fahrzeug steht bereit, wenn du es wirklich brauchst.',
    tag: 'Renault Trafic — bis 9 Sitze für Umzug & große Touren',
  },
  {
    kind: 'kfz', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/12/20221204_151256.jpg', pos: 'center 55%',
    h1a: 'Einer für', h1b: 'jeden Weg.',
    lead: 'Kombi, Kleinwagen oder E-Auto — fünf Fahrzeugklassen an festen Stellplätzen in Grasbrunn.',
    tag: 'Renault Clio Grandtour — Kombi für Einkauf & Ausflug',
  },
  {
    kind: 'mvv', img: `${base}img/mvv-foto.jpg`, pos: 'center 45%',
    h1a: 'Lieber Bus', h1b: '& Bahn?',
    lead: 'MVV-Tageskarten M-1 bis M-5 über unseren Partner Vaterstetten — <strong>ab 4 €/Tag</strong> ausleihen statt teuer kaufen.',
    tag: 'MVV-Tageskarte ab 4 €/Tag — Abholung am Bahnhof Vaterstetten',
  },
];

const cars = [
  { name: 'Renault ZOE', type: 'Elektro · emissionsfrei', badge: 'E-Auto · Wallbox', loc: 'Am Rathaus, Neukeferloh', seats: '5 Sitze', tarif: 'ab 0,45 €/km', img: heroPhoto },
  { name: 'Opel Corsa', type: 'Wendiger Stadtflitzer', badge: 'Kleinwagen', loc: 'Finkenstraße, hinter der Kirche', seats: '5 Sitze', tarif: 'ab 0,40 €/km', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2025/07/Opel-Corsa-NEU.jpg' },
  { name: 'Dacia Sandero', type: 'Günstig & praktisch', badge: 'Kleinwagen', loc: 'Ecke Waldstraße / Saarlandstraße', seats: '5 Sitze', tarif: 'ab 0,40 €/km', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2025/07/Dacia-Sandero-NEU-1.jpg' },
  { name: 'Renault Clio Grandtour', type: 'Kombi mit großem Kofferraum', badge: 'Kombi', loc: 'Standort wird ergänzt', seats: '5 Sitze · großer Kofferraum', tarif: 'ab 0,45 €/km', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/12/20221204_151256.jpg' },
  { name: 'Renault Trafic', type: 'Transporter / Bus — bis 9 Sitze', badge: 'Transporter', loc: 'Standort wird ergänzt', seats: 'bis 9 Sitze', tarif: 'ab 0,60 €/km', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/03/20220322_161630.jpg' },
];

// MVV-Tageskarten über die Kooperation (Partner Vaterstetten). Normalpreise „ca." —
// vor Go-Live mit Verein/MVV verifizieren (siehe Vorschau-Roadmap).
const ATG_MVV_PRICE = 4; // €/Tag über ATG/VAT (Vereinsangebot)
const mvvZones = [
  { id: 'M-1', label: 'M-1 · München Innenraum + Zone 1', normal: 9.9 },
  { id: 'M-2', label: 'M-2 · bis Zone 2', normal: 11.6 },
  { id: 'M-3', label: 'M-3 · bis Zone 3', normal: 13.3 },
  { id: 'M-5', label: 'M-5 · bis Zone 5 (z. B. Flughafen)', normal: 16.7 },
];

const steps = [
  { n: '1', h: 'Online melden', t: 'Kurzes Formular ausfüllen. Wir melden uns mit allen Infos zum Verein und zur Carsharing-Teilnahme.' },
  { n: '2', h: 'Unterlagen & Einlage', t: 'Ausweis und Führerschein nachreichen, einmalig 50 € Aufnahme und 600 € Einlage (bei Austritt zurück).' },
  { n: '3', h: 'Einweisung & losfahren', t: 'Kurze Einweisung vor Ort, Transponderkarte erhalten — ab dann buchst du jedes freie Fahrzeug selbst.' },
];

const faqs = [
  { q: 'Was kostet Carsharing bei ATG?', a: 'Tagsüber 1,00 €/Std., nachts 0,20 €/Std., dazu Kilometer ab 0,40 €/km je nach Fahrzeug. Einmalig 50 € Aufnahme und 600 € Einlage (bei Austritt zurück). Kein Monatsbeitrag.' },
  { q: 'Wie werde ich Mitglied?', a: 'Online melden, Ausweis und Führerschein nachreichen, Einlage zahlen, kurze Einweisung vor Ort — dann buchst du selbstständig.' },
  { q: 'Wo stehen die Fahrzeuge?', a: 'An festen Stellplätzen in Grasbrunn (u.a. Rathaus, Finkenstraße, Waldstraße/Saarlandstraße). Über die Kooperation mit Vaterstetten stehen weitere Fahrzeuge bereit.' },
  { q: 'Was sind die MVV-Karten?', a: 'Über die Kooperation mit Vaterstetten nutzbare Karten für Bus & Bahn. Abhol- und Rückgabestandort ist der Bahnhof Vaterstetten.' },
  { q: 'Gibt es einen Monatsbeitrag?', a: 'Nein. Nur die einmalige Einlage (rückzahlbar) und der Aufnahmebeitrag. Bezahlt wird nur, was gefahren wird.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Base>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />

  <!-- ============ HERO (Kino-Slider) ============ -->
  <section class="hero" id="top" aria-label="Carsharing in Grasbrunn">
    <div class="hero-bg" aria-hidden="true">
      {heroSlides.map((s, i) => (
        <div
          class:list={['hero-slide', { 'is-active': i === 0, 'hero-slide-mvv': s.kind === 'mvv' }]}
          data-h1a={s.h1a}
          data-h1b={s.h1b}
          data-lead={s.lead}
          data-tag={s.tag}
          style={`background-image:url(${s.img || `${base}img/mvv-motiv.svg`}); background-position:${s.pos};`}
        ></div>
      ))}
    </div>
    <div class="hero-scrim" aria-hidden="true"></div>

    <div class="wrap hero-inner">
      <p class="hero-kicker"><span class="dot"></span> Carsharing dahoam · Grasbrunn &amp; Umgebung</p>
      <h1 class="hero-h1" id="hero-h1">
        <span class="h1a" id="hero-h1a">{heroSlides[0].h1a}</span><br />
        <span class="hl" id="hero-h1b">{heroSlides[0].h1b}</span>
      </h1>
      <p class="hero-lead" id="hero-lead" set:html={heroSlides[0].lead}></p>
      <p class="hero-tag" id="hero-tag">{heroSlides[0].tag}</p>
      <div class="cta-row">
        <a class="btn btn-red" href="#mitglied">Mitglied werden</a>
        <a class="btn btn-yellow" href={BOOK} rel="noopener">Fahrzeug buchen</a>
      </div>
      <ul class="trust">
        <li><span class="ck">✓</span> {FLEET_TOTAL} Fahrzeuge gemeinsam mit Vaterstetten</li>
        <li><span class="ck">✓</span> Kein Monatsbeitrag</li>
        <li><span class="ck">✓</span> E-Auto, Transporter &amp; MVV-Karten</li>
      </ul>
    </div>

    <div class="hero-dots" role="tablist" aria-label="Fahrzeug-Motive wechseln">
      {heroSlides.map((s, i) => (
        <button
          class:list={['hero-dot', { 'is-on': i === 0 }]}
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`Motiv ${i + 1}`}
        ></button>
      ))}
    </div>

    <a class="hero-scrollcue" href="#so-gehts" aria-label="Weiter zu: So geht's"><span></span></a>
  </section>

  <!-- ============ STAT-LEISTE ============ -->
  <section class="stats">
    <div class="wrap stats-grid">
      <div class="stat"><b data-count="41">41</b><span>Fahrzeuge mit Vaterstetten</span></div>
      <div class="stat"><b>0&nbsp;€</b><span>Monatsbeitrag</span></div>
      <div class="stat"><b>1&nbsp;€/h</b><span>tagsüber fahren</span></div>
      <div class="stat"><b data-count="5">5</b><span>Fahrzeugklassen vor Ort</span></div>
    </div>
  </section>

  <!-- ============ SO GEHT'S ============ -->
  <section id="so-gehts" class="sec sec-white">
    <div class="wrap">
      <header class="sec-head reveal">
        <h2>In 3 Schritten Mitglied — und losgefahren</h2>
        <p>Kein kompliziertes Verfahren. Du meldest dich online, wir lernen uns kurz vor Ort kennen, dann fährst du.</p>
      </header>
      <div class="steps">
        {steps.map((s) => (
          <article class="step">
            <div class="step-num">{s.n}</div>
            <h3>{s.h}</h3>
            <p>{s.t}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ FLOTTE ============ -->
  <section id="flotte" class="sec">
    <div class="wrap">
      <header class="sec-head reveal">
        <h2>Fünf Fahrzeuge für jeden Zweck</h2>
        <p>Vom kleinen Stadtflitzer übers E-Auto bis zum Transporter für den Umzug — alle an festen Stellplätzen.</p>
      </header>
      <div class="cars">
        {cars.map((c) => (
          <article class="car">
            <div class="car-photo">
              <img src={c.img} alt={`${c.name} – Carsharing-Fahrzeug der ATG`} width="400" height="260" loading="lazy" />
              <span class="car-badge">{c.badge}</span>
            </div>
            <div class="car-body">
              <h3>{c.name}</h3>
              <p class="car-type">{c.type}</p>
              <ul class="car-meta">
                <li><span aria-hidden="true">👤</span> {c.seats}</li>
                <li><span aria-hidden="true">💶</span> {c.tarif}</li>
              </ul>
              <p class="car-loc"><span aria-hidden="true">📍</span> {c.loc}</p>
            </div>
          </article>
        ))}
        <article class="car car-coop">
          <div class="coop-inner">
            <h3>+36 Fahrzeuge nebenan</h3>
            <p>Über die Kooperation mit den Vaterstettener Auto-Teilern nutzt du eine gemeinsame Flotte — beidseitig.</p>
            <a class="btn btn-yellow" href="#kooperation">Mehr zur Kooperation</a>
          </div>
        </article>
      </div>
      <p class="note">📷 Phase 2: echte Fotos der Fahrzeuge an ihren realen Standorten + Detailseiten je Fahrzeug (Cockpit, Kofferraum, Sitze).</p>
    </div>
  </section>

  <!-- ============ STANDORTE-KARTE ============ -->
  <StandorteKarte />

  <!-- ============ MVV-KARTEN (2. Feature nach KFZ) ============ -->
  <section id="mvv" class="sec">
    <div class="wrap">
      <header class="sec-head reveal">
        <p class="kicker"><span class="dot"></span> Nicht nur Autos</p>
        <h2>Lieber Bus &amp; Bahn? Die MVV-Karten</h2>
        <p>Nicht jede Strecke braucht ein Auto. Über unseren Partner Vaterstetten leihst du günstig
          MVV-Tageskarten — ideal für die Fahrt nach München, ganz ohne eigenes Ticket.</p>
      </header>

      <div class="mvv-grid">
        <div class="mvv-info">
          <ul class="mvv-points">
            <li><b>Ab 4 €/Tag</b> — deutlich günstiger als ein normales MVV-Tagesticket.</li>
            <li><b>M-1 bis M-5</b> — vom Münchner Innenraum bis ins Umland (z. B. Flughafen).</li>
            <li><b>Einfach online buchen</b> im Buchungsportal — genau wie ein Fahrzeug.</li>
            <li><b>Abholung &amp; Rückgabe</b> am Bahnhof Vaterstetten.</li>
          </ul>
          <a class="btn btn-red" href={BOOK} rel="noopener">MVV-Karte buchen</a>
        </div>

        <div class="card mvv-calc">
          <h3>Was spare ich?</h3>
          <label for="mvv-zone">MVV-Bereich</label>
          <select id="mvv-zone">
            {mvvZones.map((z, i) => (
              <option value={z.normal} selected={i === 0}>
                {z.label} — ca. {z.normal.toLocaleString('de-DE', { minimumFractionDigits: 2 })} €/Tag
              </option>
            ))}
          </select>
          <label for="mvv-days">Dauer: <span id="mvv-dv" class="val">1 Tag</span></label>
          <input id="mvv-days" type="range" min="1" max="14" value="1" step="1" />
          <div class="mvv-compare">
            <div class="mvv-col"><span>Selbst kaufen</span><b id="mvv-normal">9,90 €</b></div>
            <div class="mvv-vs">→</div>
            <div class="mvv-col"><span>Über ATG / VAT</span><b id="mvv-atg" class="mvv-good">4,00 €</b></div>
          </div>
          <div class="mvv-save">Ersparnis: <b id="mvv-save">5,90 €</b></div>
          <p class="fine">Normalpreise ca. (MVV-Tageskarte Single) — vor Go-Live mit MVV/Verein verifizieren.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PREISE + KOSTENRECHNER ============ -->
  <section id="preise" class="sec sec-white">
    <div class="wrap">
      <header class="sec-head reveal">
        <h2>Was kostet mich das?</h2>
        <p>Du zahlst nur, was du fährst: Zeit plus Kilometer. Kein Monatsbeitrag, keine versteckten Gebühren.</p>
      </header>
      <div class="price-grid">
        <div class="card price-table">
          <h3>Tarife im Überblick</h3>
          <table>
            <tbody>
              <tr><td>Zeittarif tagsüber (8–20 Uhr)</td><td>1,00 €/h</td></tr>
              <tr><td>Zeittarif nachts (20–8 Uhr)</td><td>0,20 €/h</td></tr>
              <tr><td>Kilometer (Kleinwagen)</td><td>ab 0,40 €/km</td></tr>
              <tr><td>Kilometer (E-Auto / größer)</td><td>ab 0,45 €/km</td></tr>
              <tr><td>Kilometer (Transporter)</td><td>ab 0,60 €/km</td></tr>
              <tr><td>Aufnahmebeitrag (einmalig)</td><td>50 €</td></tr>
              <tr><td>Einlage (bei Austritt zurück)</td><td>600 €</td></tr>
              <tr><td>Monatsbeitrag</td><td><span class="free">0 € · keiner</span></td></tr>
            </tbody>
          </table>
          <p class="fine">Stand 04/2026. Versicherung inkl. (SB Haftpflicht 200 € / Kasko 600 €). Saisonaler Sprit-Aufschlag möglich.</p>
        </div>

        <div class="card calc">
          <h3>Kostenrechner</h3>
          <label for="calc-h">Dauer: <span id="calc-hv" class="val">3 Std.</span> tagsüber</label>
          <input id="calc-h" type="range" min="1" max="24" value="3" step="1" />
          <label for="calc-km">Strecke: <span id="calc-kmv" class="val">30 km</span></label>
          <input id="calc-km" type="range" min="5" max="300" value="30" step="5" />
          <label for="calc-cls">Fahrzeug</label>
          <select id="calc-cls">
            <option value="0.40">Kleinwagen (Corsa / Sandero) – 0,40 €/km</option>
            <option value="0.45">E-Auto / Clio – 0,45 €/km</option>
            <option value="0.60">Transporter (Trafic) – 0,60 €/km</option>
          </select>
          <div class="calc-result"><span>Beispielpreis</span><b id="calc-total">7,50 €</b></div>
          <p class="fine">Überschlag: Zeittarif (tags 1 €/h) + Kilometer, inkl. Versicherung. Echte Abrechnung übers Buchungssystem.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ KOOPERATION ============ -->
  <section id="kooperation" class="sec">
    <div class="wrap">
      <header class="sec-head reveal">
        <h2>Gemeinsam mit den Vaterstettener Auto-Teilern</h2>
        <p>Zwei Vereine, eine Idee: Mitglieder nutzen die Fahrzeuge beidseitig — so steht eine gemeinsame Flotte zur Verfügung.</p>
      </header>
      <div class="coop-grid">
        <div class="card">
          <h3>Eine Flotte, zwei Vereine</h3>
          <p class="muted-p">5 Fahrzeuge in Grasbrunn plus rund 36 in Vaterstetten und Baldham — gemeinsam rund <strong>41 Fahrzeuge</strong>. Als Mitglied buchst du auf beiden Seiten.</p>
          <a class="btn btn-ghost" href="https://www.carsharing-vaterstetten.de/" rel="noopener">Zu den Vaterstettener Auto-Teilern</a>
        </div>
        <div class="card card-dark">
          <h3>MVV-Karten inklusive</h3>
          <p>Über die Kooperation nutzt du MVV-Karten — flexibel mit Bus und Bahn statt Auto.</p>
          <small>Abhol- und Rückgabestandort: Bahnhof Vaterstetten.</small>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="sec sec-white">
    <div class="wrap wrap-narrow">
      <header class="sec-head reveal">
        <h2>Häufige Fragen</h2>
      </header>
      <div class="faq">
        {faqs.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.q}</summary>
            <div class="faq-a">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ MITGLIED WERDEN (CTA-Band) ============ -->
  <section id="mitglied" class="band">
    <div class="wrap band-inner">
      <h2>Möchtest du Mitglied werden?</h2>
      <p>Werd Teil von Carsharing dahoam in Grasbrunn. Wir melden uns persönlich bei dir — einfach und unverbindlich.</p>
      <div class="cta-row band-cta">
        <a class="btn btn-on-dark" href="mailto:info@atg-grasbrunn.de?subject=Mitglied%20werden%20bei%20ATG">E-Mail schreiben</a>
        <a class="btn btn-yellow" href="tel:+498921541339">089 21541339 anrufen</a>
        <a class="btn btn-outline-light" href="mailto:info@atg-grasbrunn.de?subject=R%C3%BCckruf%20gew%C3%BCnscht&body=Bitte%20ruft%20mich%20zu%20folgender%20Zeit%20an%3A%20">Rückruf anfordern</a>
      </div>
      <p class="band-fine">Phase 2: sicheres Online-Antragsformular (DSGVO-konform, verschlüsselt) mit Dokumenten-Upload.</p>
    </div>
  </section>

  <!-- Hero-Slider: Crossfade + Ken-Burns, Auto-Rotation, Dots, Tag-Wechsel -->
  <script>
    const heroSlideEls = document.querySelectorAll<HTMLElement>('.hero-slide');
    const heroDots = document.querySelectorAll<HTMLButtonElement>('.hero-dot');
    const heroTag = document.getElementById('hero-tag');
    const heroH1a = document.getElementById('hero-h1a');
    const heroH1b = document.getElementById('hero-h1b');
    const heroLead = document.getElementById('hero-lead');
    const heroInner = document.querySelector<HTMLElement>('.hero-inner');
    if (heroSlideEls.length > 1) {
      const reduceMo = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let cur = 0;
      let timer = 0;
      const apply = (el: HTMLElement) => {
        if (heroH1a) heroH1a.textContent = el.getAttribute('data-h1a') || '';
        if (heroH1b) heroH1b.textContent = el.getAttribute('data-h1b') || '';
        if (heroLead) heroLead.innerHTML = el.getAttribute('data-lead') || '';
        if (heroTag) heroTag.textContent = el.getAttribute('data-tag') || '';
      };
      const show = (n: number) => {
        cur = (n + heroSlideEls.length) % heroSlideEls.length;
        heroSlideEls.forEach((s, i) => s.classList.toggle('is-active', i === cur));
        heroDots.forEach((d, i) => {
          d.classList.toggle('is-on', i === cur);
          d.setAttribute('aria-selected', i === cur ? 'true' : 'false');
        });
        const el = heroSlideEls[cur];
        // Text kurz ausblenden → wechseln → einblenden (lesbarer Übergang)
        if (heroInner && !reduceMo) {
          heroInner.classList.add('is-switching');
          setTimeout(() => { apply(el); heroInner.classList.remove('is-switching'); }, 260);
        } else {
          apply(el);
        }
      };
      // Auto-Rotation langsamer (8,5 s) → genug Zeit zum Lesen
      const start = () => { if (!reduceMo) timer = window.setInterval(() => show(cur + 1), 8500); };
      heroDots.forEach((d, i) => d.addEventListener('click', () => { window.clearInterval(timer); show(i); start(); }));
      start();
    }
  </script>

  <!-- Kostenrechner-Logik (clientseitig; Phase 2 ggf. als Insel/Komponente) -->
  <script>
    const h = document.getElementById('calc-h') as HTMLInputElement | null;
    const km = document.getElementById('calc-km') as HTMLInputElement | null;
    const cls = document.getElementById('calc-cls') as HTMLSelectElement | null;
    const hv = document.getElementById('calc-hv');
    const kmv = document.getElementById('calc-kmv');
    const total = document.getElementById('calc-total');
    if (h && km && cls && hv && kmv && total) {
      const eur = (n: number) => n.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
      const calc = () => {
        const hours = parseInt(h.value, 10);
        const dist = parseInt(km.value, 10);
        const perKm = parseFloat(cls.value);
        hv.textContent = hours + ' Std.';
        kmv.textContent = dist + ' km';
        total.textContent = eur(hours * 1.0 + dist * perKm);
      };
      [h, km, cls].forEach((el) => el.addEventListener('input', calc));
      calc();
    }
  </script>

  <!-- MVV-Karten-Vergleichsrechner: Normalpreis vs. Vereinsangebot (4 €/Tag) -->
  <script>
    const mz = document.getElementById('mvv-zone') as HTMLSelectElement | null;
    const md = document.getElementById('mvv-days') as HTMLInputElement | null;
    const mdv = document.getElementById('mvv-dv');
    const mnrm = document.getElementById('mvv-normal');
    const matg = document.getElementById('mvv-atg');
    const msv = document.getElementById('mvv-save');
    const ATG_DAY = 4; // €/Tag über ATG/VAT
    if (mz && md && mdv && mnrm && matg && msv) {
      const eur = (n: number) => n.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
      const calc = () => {
        const d = parseInt(md.value, 10);
        const normalDay = parseFloat(mz.value);
        mdv.textContent = d + (d === 1 ? ' Tag' : ' Tage');
        const normalTotal = normalDay * d;
        const atgTotal = ATG_DAY * d;
        mnrm.textContent = eur(normalTotal);
        matg.textContent = eur(atgTotal);
        msv.textContent = eur(Math.max(0, normalTotal - atgTotal));
      };
      [mz, md].forEach((el) => el.addEventListener('input', calc));
      calc();
    }
  </script>

