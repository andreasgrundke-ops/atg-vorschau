  <!-- Kostenrechner -->
  <script>
    const h = document.getElementById('calc-h') as HTMLInputElement | null;
    const km = document.getElementById('calc-km') as HTMLInputElement | null;
    const cls = document.getElementById('calc-cls') as HTMLSelectElement | null;
    const hv = document.getElementById('calc-hv');
    const kmv = document.getElementById('calc-kmv');
    const total = document.getElementById('calc-total');
    if (h && km && cls && hv && kmv && total) {
      const eur = (n: number) => n.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
      const calc = () => {
        const hours = parseInt(h.value, 10);
        const dist = parseInt(km.value, 10);
        const perKm = parseFloat(cls.value);
        hv.textContent = hours + ' Std.';
        kmv.textContent = dist + ' km';
        total.textContent = eur(hours * 1.0 + dist * perKm);
      };
      [h, km, cls].forEach((el) => el.addEventListener('input', calc));
      calc();
    }
  </script>

  <!-- MVV-Vergleichsrechner -->
  <script>
    const mz = document.getElementById('mvv-zone') as HTMLSelectElement | null;
    const md = document.getElementById('mvv-days') as HTMLInputElement | null;
    const mdv = document.getElementById('mvv-dv');
    const mnrm = document.getElementById('mvv-normal');
    const matg = document.getElementById('mvv-atg');
    const msv = document.getElementById('mvv-save');
    const ATG_DAY = 4;
    if (mz && md && mdv && mnrm && matg && msv) {
      const eur = (n: number) => n.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
      const calc = () => {
        const d = parseInt(md.value, 10);
        const normalDay = parseFloat(mz.value);
        mdv.textContent = d + (d === 1 ? ' Tag' : ' Tage');
        const normalTotal = normalDay * d;
        const atgTotal = ATG_DAY * d;
        mnrm.textContent = eur(normalTotal);
        matg.textContent = eur(atgTotal);
        msv.textContent = eur(Math.max(0, normalTotal - atgTotal));
      };
      [mz, md].forEach((el) => el.addEventListener('input', calc));
      calc();
    }
  </script>

  <!-- DSGVO-Karte (Leaflet/OSM, lazy via IntersectionObserver) -->
  <script type="application/json" id="v2-map-data" set:html={JSON.stringify(geo)}></script>
  <script>
    import 'leaflet/dist/leaflet.css';
    const dataEl = document.getElementById('v2-map-data');
    const geo = dataEl ? JSON.parse(dataEl.textContent || '{}') : { atg: [], vat: [], mvv: null };
    const mapEl = document.getElementById('v2-map');
    let loaded = false;

    async function initMap() {
      if (loaded || !mapEl) return;
      loaded = true;
      const L = (await import('leaflet')).default;
      const map = L.map('v2-map', { scrollWheelZoom: false });
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 18, attribution: '&copy; OpenStreetMap' }).addTo(map);

      const dot = (cls: string, label = '') =>
        L.divIcon({ className: '', html: `<span class="v2pin ${cls}">${label}</span>`, iconSize: [24, 24], iconAnchor: [12, 12], popupAnchor: [0, -12] });

      const pts: [number, number][] = [];
      geo.vat.forEach((c: number[]) => {
        L.marker([c[0], c[1]], { icon: dot('v2pin-vat'), keyboard: false }).addTo(map).bindPopup('<b>Partner-Flotte Vaterstetten</b><br>Gemeinsam nutzbar über die Kooperation.');
        pts.push([c[0], c[1]]);
      });
      L.marker([geo.mvv.lat, geo.mvv.lng], { icon: dot('v2pin-mvv', 'S') }).addTo(map).bindPopup(`<b>${geo.mvv.name}</b><br>${geo.mvv.loc}`);
      pts.push([geo.mvv.lat, geo.mvv.lng]);
      geo.atg.forEach((p: any) => {
        L.marker([p.lat, p.lng], { icon: dot('v2pin-atg') }).addTo(map).bindPopup(`<b>${p.name}</b><br>${p.loc}`);
        pts.push([p.lat, p.lng]);
      });

      map.fitBounds(pts, { padding: [40, 40] });
      setTimeout(() => map.invalidateSize(), 200);
    }

    if (mapEl) {
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => { if (entries.some((e) => e.isIntersecting)) { initMap(); io.disconnect(); } }, { rootMargin: '250px' });
        io.observe(mapEl);
      } else { initMap(); }
    }
  </script>

