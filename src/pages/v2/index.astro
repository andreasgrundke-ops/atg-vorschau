---
/**
 * =====================================================================================
 * ATG Carsharing — Startseite V2 (Designentwurf, soft/clay, modern & abgerundet)
 * -------------------------------------------------------------------------------------
 * Titel:        v2/index.astro — V2-Startseite
 * Version:      2.0
 * Autor:        Grundke IT-Service
 * Datum:        2026-06-29
 * Beschreibung: Zweiter Designentwurf der ATG-Startseite. Kein Kino-Hero, sondern ein
 *               heller, freundlicher Split-Hero mit schwebenden Karten + sanften Blobs.
 *               Abgerundete „clay"-Sektionen, Scroll-Reveal, Zahlen-Counter, swipebare
 *               Flotte (App-Feeling), interaktive DSGVO-Karte (Leaflet/OSM) und Rechner.
 *               Inhalte/Fakten 1:1 aus V1 übernommen; nur Form/Aufbau/Motion sind neu.
 * Ablauf:       1) Daten (Fahrzeuge, Schritte, Preise, MVV, Geo) als Konstanten
 *               2) Sektionen Hero→Stats→So geht's→Flotte→Standorte→MVV→Preise→
 *                  Kooperation→FAQ→Kontakt/CTA
 *               3) Client-Scripts: Kostenrechner, MVV-Rechner, Leaflet-Karte
 * Änderungshistorie:
 *   2026-06-29  2.0  Erstanlage V2 (parallel zu eingefrorener V1).
 * =====================================================================================
 */
import BaseV2 from '../../layouts/BaseV2.astro';

const base = import.meta.env.BASE_URL;
const BOOK = 'https://www.atg-grasbrunn.de/mitgliederbereich/';
const FLEET_TOTAL = 41;

// Fahrzeugfotos: aktuell von der Live-Seite referenziert (wie V1) → Phase 2 lokal/WebP.
const heroPhoto = 'https://www.atg-grasbrunn.de/wp-content/uploads/2024/09/WhatsApp-Bild-2024-09-01-um-12.45.09_ef67264d-1.jpg';

const cars = [
  { name: 'Renault ZOE', type: 'Elektro · emissionsfrei', badge: 'E-Auto', loc: 'Am Rathaus, Neukeferloh', seats: '5 Sitze', tarif: 'ab 0,45 €/km', img: heroPhoto },
  { name: 'Opel Corsa', type: 'Wendiger Stadtflitzer', badge: 'Kleinwagen', loc: 'Finkenstraße, hinter der Kirche', seats: '5 Sitze', tarif: 'ab 0,40 €/km', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2025/07/Opel-Corsa-NEU.jpg' },
  { name: 'Dacia Sandero', type: 'Günstig & praktisch', badge: 'Kleinwagen', loc: 'Ecke Waldstraße / Saarlandstraße', seats: '5 Sitze', tarif: 'ab 0,40 €/km', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2025/07/Dacia-Sandero-NEU-1.jpg' },
  { name: 'Renault Clio Grandtour', type: 'Kombi mit großem Kofferraum', badge: 'Kombi', loc: 'Standort wird ergänzt', seats: '5 Sitze · XL-Kofferraum', tarif: 'ab 0,45 €/km', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/12/20221204_151256.jpg' },
  { name: 'Renault Trafic', type: 'Transporter / Bus — bis 9 Sitze', badge: 'Transporter', loc: 'Standort wird ergänzt', seats: 'bis 9 Sitze', tarif: 'ab 0,60 €/km', img: 'https://www.atg-grasbrunn.de/wp-content/uploads/2022/03/20220322_161630.jpg' },
];

// Quick-Action-Chips im Hero („Was brauchst du heute?") — App-Anmutung.
const quickPicks = [
  { label: 'Kleinwagen', href: '#flotte', icon: 'car' },
  { label: 'E-Auto', href: '#flotte', icon: 'bolt' },
  { label: 'Transporter', href: '#flotte', icon: 'truck' },
  { label: 'MVV-Karte', href: '#mvv', icon: 'train' },
];

const steps = [
  { n: '1', h: 'Online melden', t: 'Kurzes Formular ausfüllen. Wir melden uns mit allen Infos zum Verein und zur Carsharing-Teilnahme.', icon: 'pen' },
  { n: '2', h: 'Unterlagen & Einlage', t: 'Ausweis und Führerschein nachreichen, einmalig 50 € Aufnahme und 600 € Einlage (bei Austritt zurück).', icon: 'doc' },
  { n: '3', h: 'Einweisung & losfahren', t: 'Kurze Einweisung vor Ort, Transponderkarte erhalten — ab dann buchst du jedes freie Fahrzeug selbst.', icon: 'key' },
];

// MVV-Tageskarten über die Kooperation. Normalpreise „ca." — vor Go-Live verifizieren.
const mvvZones = [
  { id: 'M-1', label: 'M-1 · München Innenraum + Zone 1', normal: 9.9 },
  { id: 'M-2', label: 'M-2 · bis Zone 2', normal: 11.6 },
  { id: 'M-3', label: 'M-3 · bis Zone 3', normal: 13.3 },
  { id: 'M-5', label: 'M-5 · bis Zone 5 (z. B. Flughafen)', normal: 16.7 },
];

const faqs = [
  { q: 'Was kostet Carsharing bei ATG?', a: 'Tagsüber 1,00 €/Std., nachts 0,20 €/Std., dazu Kilometer ab 0,40 €/km je nach Fahrzeug. Einmalig 50 € Aufnahme und 600 € Einlage (bei Austritt zurück). Kein Monatsbeitrag.' },
  { q: 'Wie werde ich Mitglied?', a: 'Online melden, Ausweis und Führerschein nachreichen, Einlage zahlen, kurze Einweisung vor Ort — dann buchst du selbstständig.' },
  { q: 'Wo stehen die Fahrzeuge?', a: 'An festen Stellplätzen in Grasbrunn (u.a. Rathaus, Finkenstraße, Waldstraße/Saarlandstraße). Über die Kooperation mit Vaterstetten stehen weitere Fahrzeuge bereit.' },
  { q: 'Was sind die MVV-Karten?', a: 'Über die Kooperation mit Vaterstetten nutzbare Karten für Bus & Bahn. Abhol- und Rückgabestandort ist der Bahnhof Vaterstetten.' },
  { q: 'Gibt es einen Monatsbeitrag?', a: 'Nein. Nur die einmalige Einlage (rückzahlbar) und der Aufnahmebeitrag. Bezahlt wird nur, was gefahren wird.' },
];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};

// Geo-Daten für die DSGVO-Karte (Quelle: components/StandorteKarte.astro — bewusst hier
// gespiegelt, damit V2 designseitig unabhängig von der V1-Komponente bleibt).
const geo = {
  atg: [
    { name: 'Renault ZOE (E-Auto)', loc: 'Am Rathaus, Neukeferloh', lat: 48.09617, lng: 11.76036 },
    { name: 'Opel Corsa', loc: 'Finkenstraße, hinter der Kirche', lat: 48.09781, lng: 11.75959 },
    { name: 'Dacia Sandero', loc: 'Ecke Waldstraße / Saarlandstraße', lat: 48.0956, lng: 11.76071 },
  ],
  mvv: { name: 'MVV-Karten (M-1 & M-5)', loc: 'Bahnhof Vaterstetten — Abholung & Rückgabe', lat: 48.10801, lng: 11.77005 },
  vat: [
    [48.097018,11.77617],[48.105773,11.774258],[48.107108,11.781472],[48.0968,11.784017],
    [48.105881,11.779309],[48.109311,11.774063],[48.106881,11.764723],[48.095739,11.794837],
    [48.10267,11.780366],[48.111574,11.770139],[48.09386,11.78253],[48.0971,11.78709],
    [48.101712,11.770523],[48.105736,11.770696],[48.103934,11.786099],[48.112606,11.768162],
    [48.09937,11.77237],[48.098421,11.767818],[48.098593,11.803076],[48.104753,11.793293],
    [48.091317,11.793075],[48.10573,11.77059],[48.099385,11.796254],[48.100786,11.786774],
    [48.097226,11.775026],[48.106483,11.76578],[48.10214,11.79412],[48.100814,11.788168],
    [48.095624,11.780117],[48.099235,11.780905],[48.110466,11.775553],[48.104648,11.787921],
    [48.097018,11.776209],[48.10267,11.780367],[48.105736,11.770797],[48.098593,11.803077],
  ],
};

// Inline-SVG-Icons (Lucide-Stil) — als Map, damit das Markup schlank bleibt.
const ICONS: Record<string, string> = {
  car: '<path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 1 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/>',
  bolt: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>',
  truck: '<path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5v8h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>',
  train: '<rect x="4" y="3" width="16" height="14" rx="3"/><path d="M4 11h16"/><circle cx="8.5" cy="14" r="1"/><circle cx="15.5" cy="14" r="1"/><path d="m8 17-2 4M16 17l2 4"/>',
  pen: '<path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>',
  doc: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h4"/>',
  key: '<circle cx="7.5" cy="15.5" r="4.5"/><path d="m21 2-9.6 9.6"/><path d="m15.5 7.5 3 3L22 7l-3-3"/>',
};
---

<BaseV2>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />

  <!-- ===================== HERO (heller Split-Hero, kein Kino) ===================== -->
  <section class="hero" id="top" aria-label="Carsharing in Grasbrunn">
    <span class="blob blob-red" style="width:38vw;height:38vw;top:-10vw;right:-8vw;"></span>
    <span class="blob blob-yellow" style="width:30vw;height:30vw;bottom:-14vw;left:-10vw;"></span>

    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow"><span class="dot"></span> Carsharing dahoam · Grasbrunn &amp; Umgebung</p>
        <h1 class="hero-h1">Teil dir ein Auto.<br /><span class="hl">Statt eins zu besitzen.</span></h1>
        <p class="hero-lead">
          Vom E-Auto bis zum 9-Sitzer — direkt um die Ecke in Grasbrunn, gemeinsam mit den
          Vaterstettener Auto-Teilern. <strong>Ohne Monatsbeitrag.</strong> Du zahlst nur, was du fährst.
        </p>

        <div class="cta-row">
          <a class="btn btn-red btn-lg" href="#mitglied">Mitglied werden</a>
          <a class="btn btn-ghost btn-lg" href={BOOK} rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
            Fahrzeug buchen
          </a>
        </div>

        <div class="quick">
          <span class="quick-label">Was brauchst du heute?</span>
          <div class="quick-chips">
            {quickPicks.map((q) => (
              <a class="chip tap" href={q.href}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS[q.icon]} />
                {q.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="hero-stage">
        <div class="hero-photo card-clay">
          <img src={heroPhoto} alt="Renault ZOE — E-Carsharing-Fahrzeug der ATG in Grasbrunn" width="640" height="520" fetchpriority="high" />
        </div>
        <!-- schwebende Mini-Karten (App-Look) -->
        <div class="float-card fc-1 card">
          <span class="fc-ico fc-green"><span class="pulse"></span></span>
          <div><b>Jetzt verfügbar</b><small>E-Auto am Rathaus</small></div>
        </div>
        <div class="float-card fc-2 card">
          <span class="fc-ico fc-red">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 1 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
          </span>
          <div><b class="tnum" data-count={FLEET_TOTAL}>41</b><small>Fahrzeuge mit Vaterstetten</small></div>
        </div>
        <div class="float-card fc-3 card">
          <span class="fc-ico fc-yellow">€</span>
          <div><b>ab 1 €/h</b><small>tagsüber fahren</small></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== STATS (clay-Chips, Counter) ===================== -->
  <section class="sec-tight stats-sec">
    <div class="wrap stats-row">
      <div class="stat-pill tap reveal" style="--i:0"><b class="tnum" data-count="41">41</b><span>Fahrzeuge</span></div>
      <div class="stat-pill tap reveal" style="--i:1"><b>0&nbsp;€</b><span>Monatsbeitrag</span></div>
      <div class="stat-pill tap reveal" style="--i:2"><b>1&nbsp;€/h</b><span>tagsüber</span></div>
      <div class="stat-pill tap reveal" style="--i:3"><b class="tnum" data-count="5">5</b><span>Fahrzeugklassen</span></div>
    </div>
  </section>

  <!-- ===================== SO GEHT'S ===================== -->
  <section id="so-gehts" class="sec">
    <div class="wrap">
      <header class="sec-head">
        <p class="eyebrow"><span class="dot"></span> In 3 Schritten</p>
        <h2>Mitglied werden — und losfahren</h2>
        <p>Kein kompliziertes Verfahren. Du meldest dich online, wir lernen uns kurz vor Ort kennen, dann fährst du.</p>
      </header>
      <div class="steps">
        {steps.map((s, i) => (
          <article class="step card card-clay tap reveal" style={`--i:${i}`}>
            <span class="step-ico">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS[s.icon]} />
              <i class="step-num">{s.n}</i>
            </span>
            <h3>{s.h}</h3>
            <p>{s.t}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== FLOTTE (swipebares Karussell auf Mobile) ===================== -->
  <section id="flotte" class="sec sec-warm">
    <div class="wrap">
      <header class="sec-head">
        <p class="eyebrow"><span class="dot"></span> Die Flotte</p>
        <h2>Fünf Fahrzeuge für jeden Zweck</h2>
        <p>Vom kleinen Stadtflitzer übers E-Auto bis zum Transporter — alle an festen Stellplätzen. Auf dem Handy einfach durchwischen.</p>
      </header>
    </div>

    <div class="fleet-rail" role="list">
      {cars.map((c, i) => (
        <article class="fleet-card card card-clay tap reveal" role="listitem" style={`--i:${i}`}>
          <div class="fleet-photo">
            <img src={c.img} alt={`${c.name} — Carsharing-Fahrzeug der ATG`} width="420" height="280" loading="lazy" />
            <span class="fleet-badge chip chip-yellow">{c.badge}</span>
          </div>
          <div class="fleet-body">
            <h3>{c.name}</h3>
            <p class="fleet-type">{c.type}</p>
            <div class="fleet-meta">
              <span class="chip">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                {c.seats}
              </span>
              <span class="chip chip-red tnum">{c.tarif}</span>
            </div>
            <p class="fleet-loc">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              {c.loc}
            </p>
          </div>
        </article>
      ))}
      <article class="fleet-card fleet-coop card-dark tap reveal" role="listitem" style={`--i:${cars.length}`}>
        <div class="coop-inner">
          <span class="coop-plus">+36</span>
          <h3>Fahrzeuge nebenan</h3>
          <p>Über die Kooperation mit den Vaterstettener Auto-Teilern nutzt du eine gemeinsame Flotte — beidseitig.</p>
          <a class="btn btn-yellow" href="#kooperation">Mehr zur Kooperation</a>
        </div>
      </article>
    </div>
    <div class="wrap"><p class="note">📷 Phase 2: echte Fotos der Fahrzeuge an ihren realen Standorten + Detailseiten je Fahrzeug.</p></div>
  </section>

  <!-- ===================== STANDORTE (DSGVO-Karte, V2-Optik) ===================== -->
  <section id="standorte" class="sec">
    <div class="wrap">
      <header class="sec-head">
        <p class="eyebrow"><span class="dot"></span> Standorte</p>
        <h2>Direkt vor der Haustür</h2>
        <p>ATG-Fahrzeuge an festen Stellplätzen in Neukeferloh, plus rund 36 weitere über die
          Kooperation mit Vaterstetten — und MVV-Karten am Bahnhof Vaterstetten.</p>
      </header>
      <div class="map-legend">
        <span class="chip lg-atg"><i></i> ATG Grasbrunn (3)</span>
        <span class="chip lg-vat"><i></i> Partner Vaterstetten (~36)</span>
        <span class="chip lg-mvv"><i>S</i> MVV · Bahnhof Vaterstetten</span>
      </div>
      <div class="map-frame card card-clay">
        <div id="v2-map" class="map" role="img" aria-label="Karte mit Carsharing-Standorten in Grasbrunn und Vaterstetten"></div>
      </div>
      <p class="note">Karte: © OpenStreetMap-Mitwirkende · datensparsam, ohne Google-Tracking. Standorte ungefähr — genaue Stellplätze im Buchungssystem.</p>
    </div>
  </section>

  <!-- ===================== MVV-KARTEN + Rechner ===================== -->
  <section id="mvv" class="sec sec-warm">
    <div class="wrap">
      <header class="sec-head">
        <p class="eyebrow"><span class="dot"></span> Nicht nur Autos</p>
        <h2>Lieber Bus &amp; Bahn? Die MVV-Karten</h2>
        <p>Nicht jede Strecke braucht ein Auto. Über unseren Partner Vaterstetten leihst du günstig MVV-Tageskarten — ideal für die Fahrt nach München.</p>
      </header>

      <div class="mvv-grid">
        <div class="mvv-info card card-clay reveal">
          <ul class="ticks">
            <li><b>Ab 4 €/Tag</b> — deutlich günstiger als ein normales MVV-Tagesticket.</li>
            <li><b>M-1 bis M-5</b> — vom Münchner Innenraum bis ins Umland (z. B. Flughafen).</li>
            <li><b>Einfach online buchen</b> — genau wie ein Fahrzeug.</li>
            <li><b>Abholung &amp; Rückgabe</b> am Bahnhof Vaterstetten.</li>
          </ul>
          <a class="btn btn-red" href={BOOK} rel="noopener">MVV-Karte buchen</a>
        </div>

        <div class="card card-dark mvv-calc reveal" style="--i:1">
          <h3>Was spare ich?</h3>
          <label for="mvv-zone">MVV-Bereich</label>
          <select id="mvv-zone">
            {mvvZones.map((z, i) => (
              <option value={z.normal} selected={i === 0}>
                {z.label} — ca. {z.normal.toLocaleString('de-DE', { minimumFractionDigits: 2 })} €/Tag
              </option>
            ))}
          </select>
          <label for="mvv-days">Dauer: <span id="mvv-dv" class="val">1 Tag</span></label>
          <input id="mvv-days" type="range" min="1" max="14" value="1" step="1" />
          <div class="cmp">
            <div class="cmp-col"><span>Selbst kaufen</span><b id="mvv-normal" class="tnum">9,90 €</b></div>
            <div class="cmp-arrow">→</div>
            <div class="cmp-col"><span>Über ATG / VAT</span><b id="mvv-atg" class="good tnum">4,00 €</b></div>
          </div>
          <div class="save">Ersparnis: <b id="mvv-save" class="tnum">5,90 €</b></div>
          <p class="fine">Normalpreise ca. (MVV-Tageskarte Single) — vor Go-Live verifizieren.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== PREISE + Kostenrechner ===================== -->
  <section id="preise" class="sec">
    <div class="wrap">
      <header class="sec-head">
        <p class="eyebrow"><span class="dot"></span> Preise</p>
        <h2>Was kostet mich das?</h2>
        <p>Du zahlst nur, was du fährst: Zeit plus Kilometer. Kein Monatsbeitrag, keine versteckten Gebühren.</p>
      </header>

      <div class="price-grid">
        <div class="card card-clay price-table reveal">
          <h3>Tarife im Überblick</h3>
          <dl class="prices">
            <div><dt>Zeittarif tagsüber (8–20 Uhr)</dt><dd class="tnum">1,00 €/h</dd></div>
            <div><dt>Zeittarif nachts (20–8 Uhr)</dt><dd class="tnum">0,20 €/h</dd></div>
            <div><dt>Kilometer (Kleinwagen)</dt><dd class="tnum">ab 0,40 €/km</dd></div>
            <div><dt>Kilometer (E-Auto / größer)</dt><dd class="tnum">ab 0,45 €/km</dd></div>
            <div><dt>Kilometer (Transporter)</dt><dd class="tnum">ab 0,60 €/km</dd></div>
            <div><dt>Aufnahmebeitrag (einmalig)</dt><dd class="tnum">50 €</dd></div>
            <div><dt>Einlage (bei Austritt zurück)</dt><dd class="tnum">600 €</dd></div>
            <div><dt>Monatsbeitrag</dt><dd><span class="free">0 € · keiner</span></dd></div>
          </dl>
          <p class="fine">Stand 04/2026. Versicherung inkl. (SB Haftpflicht 200 € / Kasko 600 €). Saisonaler Sprit-Aufschlag möglich.</p>
        </div>

        <div class="card card-dark calc reveal" style="--i:1">
          <h3>Kostenrechner</h3>
          <label for="calc-h">Dauer: <span id="calc-hv" class="val">3 Std.</span> tagsüber</label>
          <input id="calc-h" type="range" min="1" max="24" value="3" step="1" />
          <label for="calc-km">Strecke: <span id="calc-kmv" class="val">30 km</span></label>
